# Copy this file to `.env` and fill in your Supabase project values for local dev.
# Both are safe to expose in client code: the anon key is designed for the
# browser, and security is enforced by the row-level-security policies in
# supabase/migrations/. Leave them blank to keep running on the local mock.
#
# For the live site, set the same two as GitHub Actions secrets (see
# docs/SUPABASE_SETUP.md) so the production build picks them up.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
